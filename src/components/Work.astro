---
const projects = [
  {
    title: 'Data Protection Platform',
    context: 'Nubank',
    description: 'LGPD compliance systems for millions of customers. Data classification, regulatory requirements, scale.',
    stack: ['Clojure', 'Datomic', 'Kafka', 'AWS'],
  },
  {
    title: 'Investment Platform',
    context: 'Nubank',
    description: 'Services for variable income products. Real-time data, financial correctness, distributed transactions.',
    stack: ['Clojure', 'Datomic', 'Kafka', 'AWS'],
  },
  {
    title: 'Education Platform',
    context: 'Fractal Tecnologia',
    description: 'LMS and E-learning applications. Technical leadership, architecture decisions, DevOps infrastructure.',
    stack: ['React', 'Ruby on Rails', 'PostgreSQL', 'AWS'],
  },
];
---

<section id="work" class="py-24 sm:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <span class="section-heading block">Selected Work</span>

    <div class="space-y-4">
      {projects.map((project) => (
        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
            <h3 class="text-white font-medium">{project.title}</h3>
            <span class="text-xs font-mono text-accent shrink-0">{project.context}</span>
          </div>

          <p class="text-muted text-sm leading-relaxed mb-4">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-2">
            {project.stack.map((tech) => (
              <span class="text-xs font-mono px-2 py-1 rounded bg-accent/10 text-accent/80">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

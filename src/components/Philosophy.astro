---
const principles = [
  { number: '01', title: 'Simplicity is a feature', description: 'Complexity should be earned, not inherited.' },
  { number: '02', title: 'Functional thinking', description: 'Immutability and pure functions as architectural principles.' },
  { number: '03', title: 'Correctness first', description: 'A fast wrong answer is worse than a slow right one.' },
  { number: '04', title: 'Architecture is communication', description: 'Make the system legible to the team, not just the compiler.' },
  { number: '05', title: 'Leadership is multiplying', description: 'Make the team better, not just the codebase.' },
];
---

<section id="philosophy" class="py-24 sm:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <span class="section-heading block">Engineering Philosophy</span>

    <div class="max-w-2xl space-y-6">
      {principles.map((p) => (
        <div class="flex gap-6">
          <span class="text-sm font-mono text-accent/40 pt-0.5 shrink-0">{p.number}</span>
          <div>
            <h3 class="text-white font-medium mb-1">{p.title}</h3>
            <p class="text-muted text-sm">{p.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

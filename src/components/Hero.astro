---
const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/renanrboliveira',
    icon: `<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/renanrboliveira',
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
];
---

<section class="min-h-[90vh] flex items-center pt-14">
  <div class="max-w-5xl mx-auto px-6 w-full">
    <div class="flex flex-col-reverse lg:flex-row lg:items-center lg:justify-between gap-12">
      <div class="max-w-2xl">
        <div class="mb-6">
          <span class="inline-block text-xs font-mono text-accent tracking-wider uppercase">
            Lead Software Engineer
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-[1.1] mb-6">
          Building resilient<br />
          <span class="text-muted">financial systems</span><br />
          <span class="text-muted">at scale.</span>
        </h1>

        <p class="text-lg text-muted max-w-lg leading-relaxed mb-10">
          Software architecture, distributed systems, and the engineering
          that financial products demand — correctness, reliability, and scale.
        </p>

        <div class="flex items-center gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-muted hover:text-white transition-colors duration-200 group"
              aria-label={link.label}
            >
              <svg
                class="w-5 h-5 fill-current"
                viewBox="0 0 24 24"
                set:html={link.icon}
              />
              <span class="hidden sm:inline">{link.label}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="shrink-0">
        <img
          src="/profile.jpg"
          alt="Renan Oliveira"
          width="200"
          height="240"
          class="w-40 h-48 lg:w-48 lg:h-56 rounded-2xl object-cover ring-1 ring-border grayscale hover:grayscale-0 transition-all duration-500"
        />
      </div>
    </div>

    <!-- Subtle scroll indicator -->
    <div class="mt-20 flex justify-start">
      <a href="#about" class="text-muted/40 hover:text-muted transition-colors" aria-label="Scroll down">
        <svg width="16" height="24" viewBox="0 0 16 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="8" y1="2" x2="8" y2="20" />
          <polyline points="3,16 8,21 13,16" />
        </svg>
      </a>
    </div>
  </div>
</section>
